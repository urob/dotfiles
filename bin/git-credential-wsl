#!/usr/bin/env bash
# Portable git credential helper.
#   - On WSL: delegate to the Windows Git Credential Manager (shared Windows store).
#   - Elsewhere: fall back to libsecret, then the credential cache.
# Referenced from gitconfig as:  helper = !"$HOME/bin/git-credential-wsl"

# Locate the shared probe relative to this script (resolves through the ~/bin symlink).
_self="$(readlink -f "${BASH_SOURCE[0]}")"
. "$(dirname "$_self")/_wsl-gcm.sh"

if gcm="$(detect_gcm)"; then
    exec "$gcm" "$@"
fi

# Non-WSL fallbacks.
for _helper in git-credential-libsecret git-credential-cache; do
    if command -v "$_helper" >/dev/null 2>&1; then
        exec "$_helper" "$@"
    fi
done

# Nothing available: succeed silently so git proceeds (e.g. for ssh remotes).
exit 0
